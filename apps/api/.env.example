PORT=4000
NODE_ENV=development
# Bisa satu origin atau comma-separated list, contoh:
# CORS_ORIGIN=http://localhost:5173,https://kasir.example.com
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aviaoutdoor?schema=public

# Ganti nilai di bawah ini sebelum production.
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h
PASSWORD_PEPPER=change-this-too
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Login brute-force protection
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_BLOCK_MS=900000
