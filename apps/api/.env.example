PORT=4000
HOST=0.0.0.0
NODE_ENV=development
# Bisa satu origin atau comma-separated list, contoh:
# CORS_ORIGIN=http://localhost:5173,https://kasir.example.com
CORS_ORIGIN=http://localhost:5173
# Khusus smoke test production lokal; jangan aktifkan untuk origin non-loopback.
ALLOW_INSECURE_LOOPBACK_CORS=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aviaoutdoor?schema=public

# Ganti nilai di bawah ini sebelum production.
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h
PASSWORD_PEPPER=change-this-too
ADMIN_USERNAME=admin@gmail.com
ADMIN_PASSWORD=replace-with-at-least-16-characters

# Login brute-force protection
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_BLOCK_MS=900000
LOGIN_RATE_LIMIT_MAX_BUCKETS=10000

# Request resource limits
# Production ceilings: 10485760 bytes and 60000 ms.
REQUEST_BODY_LIMIT_BYTES=1048576
REQUEST_BODY_TIMEOUT_MS=10000

# HTTP connection limits
# Production ceilings: request 120000, headers/keep-alive 60000 ms, socket 10000 requests.
SERVER_REQUEST_TIMEOUT_MS=15000
SERVER_HEADERS_TIMEOUT_MS=10000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
SERVER_MAX_REQUESTS_PER_SOCKET=1000

# Set true only when the trusted reverse proxy overwrites X-Forwarded-For.
TRUST_PROXY=false
